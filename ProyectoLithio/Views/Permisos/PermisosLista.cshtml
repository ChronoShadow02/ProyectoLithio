@model List<ProyectoLithio.Models.pa_Permisos_Select_Result>
@{
    ViewBag.Title = "Lista de Permisos";
    Layout = "~/Views/Shared/_LayoutCosteo.cshtml";
}

<h2>Lista de Permisos</h2>
<br />
<div class="row">
    <div class="col-lg-12">
        <div class="table-responsive">
            <table id="tablaDataTable" class="table table-striped table-bordered dt-responsive nowrap bg-white">
                <thead>
                    <tr>
                        <th>Identificador</th>
                        <th>Nombre Completo</th>
                        <th>Tipo de usuario</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var oListaPermisos in this.Model)
                    {
                        <tr>
                            <td>@oListaPermisos.Id_Usuario</td>
                            <td>@oListaPermisos.Primer_Nombre @oListaPermisos.Primer_Apellido @oListaPermisos.Segundo_Apellido</td>
                            <td>@oListaPermisos.Desc_Tipo_Usuario</td>
                            <td>@oListaPermisos.Desc_Estado_Usuario</td>
                            <td><a href="~/Permisos/PermisosModifica" class="btn btn-success">Editar</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
<br />
<br />
<div class="row">
    <div class="col-lg-12 text-center">
        <a href="~/Usuarios/UsuariosNuevo" class="btn btn-primary">Nuevo usuario</a>
    </div>
</div>

<br />
@section scripts{
    <script src="~/Scripts/Tablas/datatables.min.js"></script>
    <script src="~/Scripts/Tablas/mensajesGenericosDataTables.js"></script>
}




