
@{
    ViewBag.Title = "Nuevo usuario";
    Layout = "~/Views/Shared/_LayoutCosteo.cshtml";
}

<h2>Nuevo usuario</h2>
<br />
<form method="post" id="frmUsuario">
    <label><span class="Obligatorio">* Obligatorio</span></label> <br />
    <div class="form-group">
        <label><span class="Obligatorio">*</span>Nombre</label>
        <input type="text" name="Primer_Nombre" class="form-control" placeholder="Ejemplo:Juan" id="Primer_Nombre" />
    </div>
    <div class="form-group">
        <label><span class="Obligatorio">*</span>Primer apellido</label>
        <input type="text" name="Primer_Apellido" class="form-control" placeholder="Ejemplo:Pérez" id="Primer_Apellido" />
    </div>
    <div class="form-group">
        <label><span class="Obligatorio">*</span>Segundo apellido</label>
        <input type="text" name="Segundo_Apellido" class="form-control" placeholder="Ejemplo:Pérez" id="Segundo_Apellido" />
    </div>
    <div class="form-group">
        <label><span class="Obligatorio">*</span>Correo Electrónico</label>
        <input type="text" name="Correo_Electronico" class="form-control" id="Correo_Electronico" />
    </div>
    <div class="form-group">
        <label><span class="Obligatorio">*</span>Contraseña</label>
        <input type="password" name="Contrasena_Usuario" class="form-control" id="Contrasena_Usuario" />
    </div>
    <div class="form-group text-right">
        <input type="submit" value="Ingresar" class="btn-success btn" id="btnAgregarUsuario" />
        <a href="~/Usuarios/UsuariosLista" class="btn btn-info">Regresar a la lista</a>
    </div>
</form>
@section scripts{
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/validacionesGenericas.js"></script>
    <script src="~/Scripts/Usuarios/validarUsuarios.js"></script>
}